# ════════════════════════════════════════════════════════════════════════
# SmartSys ERP - Environment Configuration Example
# ════════════════════════════════════════════════════════════════════════
# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
# Copy this file to .env and edit values according to your environment
# ════════════════════════════════════════════════════════════════════════

# ════════════════════════════════════════
# 🔧 إعدادات البيئة الأساسية
# ════════════════════════════════════════
# development / staging / production
APP_ENV=development
# true / false - Enable debug mode in development only
APP_DEBUG=true

# ════════════════════════════════════════
# 🗄️  إعدادات قاعدة البيانات
# ════════════════════════════════════════
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=inventory
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# ════════════════════════════════════════
# 🔐 إعدادات الأمان والمصادقة
# ════════════════════════════════════════
# ⚠️ SECURITY: Generate fresh secrets per environment. Never reuse across envs.
# Generate with: php -r "echo bin2hex(random_bytes(32));"
#
# JWT Secret for access tokens (REQUIRED: 64 hex chars / 256-bit entropy)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
# JWT Secret for refresh tokens (REQUIRED: must differ from JWT_SECRET)
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
# JWT access token expiry in seconds (default: 3600 = 1 hour)
JWT_ACCESS_TOKEN_EXPIRY=3600
# JWT refresh token expiry in seconds (default: 2592000 = 30 days)
JWT_REFRESH_TOKEN_EXPIRY=2592000
# JWT algorithm (default: HS256)
JWT_ALGORITHM=HS256
# Secret key for Cron jobs (used in X-Cron-Token header)
CRON_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ════════════════════════════════════════
# 📝 إعدادات اللوج والرصد
# ════════════════════════════════════════
# debug / info / warning / error / critical
LOG_LEVEL=debug
MONOLOG_CHANNEL=erp
# Number of log files to keep
MONOLOG_MAX_FILES=30
# Path for log files (relative to project root)
MONOLOG_LOG_PATH=/logs
# Enable session debug logging (0/1)
SESSIONS_DEBUG=1

# ════════════════════════════════════════
# 🌐 إعدادات الـ API والمسارات
# ════════════════════════════════════════
# Application URL for email verification links, password resets, etc.
# Used by: EmailVerificationHandler, StrictSubscriptionHandler
# في بيئة التطوير: http://localhost:3000
# في الإنتاج: https://yourdomain.com
APP_URL=http://localhost:3000
# Base path for API routing
# المسار الأساسي للـ API (يجب أن يكون /smartsys/api/v1)
APP_BASE_PATH=/smartsys/api/v1
# Base URL for Axios/Frontend API calls
API_BASE_URL=http://localhost:8000
# Admin API endpoint for cron jobs
ADMIN_API_URL=http://localhost:8000/smartsys/api/v1/admin/subscriptions/cron

# ════════════════════════════════════════
# 🗄️  إعدادات Redis (Cache/Rate Limiting)
# ════════════════════════════════════════
# Enable Redis for distributed rate limiting (true/false)
REDIS_ENABLED=false
# Redis host address
REDIS_HOST=127.0.0.1
# Redis port
REDIS_PORT=6379
# Redis password (leave empty if no auth)
REDIS_PASSWORD=
# Redis database number (default: 0)
REDIS_DATABASE=0

# ════════════════════════════════════════
# 📧 إعدادات البريد (SMTP)
# ════════════════════════════════════════
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_password_or_app_pass
# tls / ssl
SMTP_SECURE=tls
# Sender email address
SMTP_FROM=your_email@gmail.com
SMTP_FROM_NAME=SmartSys
# SMTP connection timeout in seconds (default: 15)
SMTP_TIMEOUT=15
# Max PHP execution time for email operations in seconds (default: 60)
EMAIL_MAX_EXECUTION_TIME=60

# ════════════════════════════════════════
# 💳 إعدادات بوابات الدفع
# ════════════════════════════════════════
# Tap Payment Gateway Secret Key (used by PaymentIntegrationHandler)
TAP_SECRET_KEY=your_tap_secret_key
# MyFatoorah Payment Gateway API Key (used by PaymentIntegrationHandler)
MYFATOORAH_API_KEY=your_myfatoorah_api_key

# ════════════════════════════════════════
# ⚡ إعدادات Rate Limiting
# ════════════════════════════════════════
# Enable rate limiting globally (true/false)
RATE_LIMIT_ENABLED=true
# Default time window in seconds
RATE_LIMIT_WINDOW=60
# Max requests per window (global)
RATE_LIMIT_MAX_ATTEMPTS=60
# Rate limiting window for login endpoint (seconds)
RATE_LIMIT_LOGIN_WINDOW=600
# Max login attempts per window
RATE_LIMIT_LOGIN_ATTEMPTS=10

# ════════════════════════════════════════
# 🔒 إعدادات الأمان الإضافية
# ════════════════════════════════════════
# Enable security event logging (true/false)
SECURITY_LOGGING_ENABLED=true
# Keep security logs for N days
SECURITY_LOG_RETENTION_DAYS=365
# Trust X-Forwarded-For header behind proxy (true/false)
TRUST_PROXY=true
# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://127.0.0.1:3000
# Allow all origins (WARNING: insecure in production - use only for testing)
CORS_ALLOW_ALL=false
