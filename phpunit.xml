<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
         stopOnFailure="false"
         displayDetailsOnTestsThatTriggerWarnings="true"
         displayDetailsOnTestsThatTriggerDeprecations="true">

    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Integration">
            <directory>tests/Integration</directory>
        </testsuite>
    </testsuites>

    <coverage>
        <include>
            <directory suffix=".php">api/v1/src</directory>
            <directory suffix=".php">api/v1/handlers</directory>
            <directory suffix=".php">api/v1/middleware</directory>
        </include>
        <report>
            <html outputDirectory="coverage/html"/>
            <text outputFile="coverage/coverage.txt" showUncoveredFiles="false"/>
        </report>
    </coverage>

    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_DEBUG" value="false"/>
        <env name="DB_HOST" value="localhost"/>
        <env name="DB_DATABASE" value="inventory_test"/>
        <env name="DB_USERNAME" value="root"/>
        <env name="DB_PASSWORD" value=""/>
        <env name="JWT_SECRET" value="test_jwt_secret_for_unit_tests_only_256bit"/>
        <env name="JWT_REFRESH_SECRET" value="test_refresh_secret_for_unit_tests_only"/>
        <env name="APP_2FA_KEY" value="test_2fa_key_for_unit_tests_only_32chars"/>
    </php>
</phpunit>
