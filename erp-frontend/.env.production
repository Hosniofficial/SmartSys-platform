# إعدادات الإنتاج - Production Configuration

# الـ API Base URL - سيتم استخدام المسار الأساسي عند عدم تحديده
# اترك مفروغ منه لاستخدام المسار الافتراضي: /smartsys/api/v1
# أو عدّله حسب احتياجات الخادم الخاص بك
VITE_API_BASE_URL=/smartsys/api/v1

# Note: VITE_API_TARGET is only used by vite.config.js during development
# In production, build is static and uses VITE_API_BASE_URL

# إعدادات اللوج الموحدة للـ Frontend
VITE_APP_ENV=production
VITE_LOG_LEVEL=warn
