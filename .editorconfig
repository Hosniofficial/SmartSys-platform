# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

# Top-most EditorConfig file
root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# PHP files
[*.php]
indent_size = 4

# JavaScript, TypeScript, Vue files
[*.{js,jsx,ts,tsx,vue}]
indent_size = 2

# JSON, YAML files
[*.{json,yml,yaml}]
indent_size = 2

# CSS, SCSS files
[*.{css,scss,sass,less}]
indent_size = 2

# HTML files
[*.html]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# Makefiles
[Makefile]
indent_style = tab

# Shell scripts
[*.sh]
end_of_line = lf
indent_size = 2

# Windows batch files
[*.{bat,cmd}]
end_of_line = crlf

# Package files
[{package.json,composer.json}]
indent_size = 2

# Configuration files
[{.babelrc,.stylelintrc,.eslintrc,*.config.js}]
indent_size = 2
